{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: cl.exe build active file",
            "command": "powershell",
            "args": [
                "-Command",
                "Get-Process -Name Game -ErrorAction SilentlyContinue | Stop-Process -Force;",
                "cl.exe /Zi /EHsc /nologo /Fe:${workspaceFolder}\\build\\Game.exe /Fo:${workspaceFolder}\\build\\ /Fd:${workspaceFolder}\\build\\ ${workspaceFolder}\\src\\Main.cpp ${workspaceFolder}\\src\\Attributes\\Type.cpp ${workspaceFolder}\\src\\Spells\\basicSpell.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}